# Jira / Confluence (Atlassian)
ATLASSIAN_DOMAIN=bagelcode.atlassian.net
ATLASSIAN_EMAIL=your-email@bagelcode.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token
JIRA_PROJECT=GS

# OpenAI (검색어 번역 + Hub AI 채팅)
OPENAI_API_KEY=your-openai-api-key

# MCP SSE 서버 (Google Drive 검색 + GS OS 온톨로지)
MCP_SSE_URL=http://your-mcp-server:3100

# repob 바이너리 경로 (사내 repo 검색)
REPOB_BIN=/path/to/repob

